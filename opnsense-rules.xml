<group name="opnsense, custom">
    <!-- Base Rule: Grouping OPNsense firewall logs -->
    <rule id="100900" level="0">
        <decoded_as>opnsense-custom</decoded_as>
        <field name="logsource">filterlog</field>
        <description>opnsense firewall rules grouped.</description>
        <group>firewall_allow,pci_dss_1.4,gpg13_4.12</group>
    </rule>

    <!-- Sub-Rule: Firewall Allow Event -->
    <rule id="100901" level="4">
        <if_sid>100900</if_sid>
        <action>pass</action>
        <options>no_full_log</options>
        <description>opnsense firewall allow event.</description>
        <group>firewall_allow,pci_dss_1.4</group>
    </rule>

    <!-- Sub-Rule: Firewall Block/Drop Event -->
    <rule id="100902" level="5">
        <if_sid>100900</if_sid>
        <action>block</action>
        <options>no_full_log</options>
        <description>opnsense firewall drop event.</description>
        <group>firewall_block,pci_dss_1.4</group>
    </rule>

    <!-- Security Rule: Detecting brute force or scanning (Multiple Blocks) -->
    <rule id="100903" level="10" frequency="18" timeframe="45">
        <if_matched_sid>100902</if_matched_sid>
        <same_source_ip />
        <description>Multiple opnsense firewall blocks events from same source.</description>
        <mitre>
            <id>T1118</id>
        </mitre>
        <group>multiple_blocks,pci_dss_1.4,pci_dss_10.6.1,gpg13-4.12</group>
    </rule>
</group>
